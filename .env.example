# --- Database -----------------------------------------------------------------
# Local Postgres example:
#   postgresql://postgres:postgres@localhost:5432/levelplay?schema=public
# Azure DB for PostgreSQL (prod) example:
#   postgresql://USER:PASSWORD@SERVER.postgres.database.azure.com:5432/levelplay?sslmode=require
# Only this one value changes between local / dev / prd.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/levelplay?schema=public"

# --- Auth ---------------------------------------------------------------------
# Used to sign session cookies. Generate a long random string for each env.
SESSION_SECRET="change-me-in-every-environment-to-a-long-random-string"

# --- Environment --------------------------------------------------------------
# dev = POC environment, prd = production. Affects banners/labels only for now.
APP_ENV="dev"

# --- Azure AD (later) ---------------------------------------------------------
# Left blank for the local POC. When you move to Entra ID, fill these and the
# auth layer swaps from seeded users to Azure AD group-based roles.
AZURE_AD_TENANT_ID=""
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
